  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "전체 이벤트 (24시간)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT COUNT(*) as value FROM user_events WHERE time > NOW() - INTERVAL '24 hours'",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "순 방문자 (24시간)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT COUNT(DISTINCT user_id) as value FROM user_events WHERE time > NOW() - INTERVAL '24 hours' AND user_id IS NOT NULL",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "페이지뷰 (24시간)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT COUNT(*) as value FROM user_events WHERE time > NOW() - INTERVAL '24 hours' AND event_type = 'page_view'",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 8,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "title": "서비스별 이벤트 (24시간)",
      "type": "bargauge",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT service_id as metric, COUNT(*) as value FROM user_events WHERE time > NOW() - INTERVAL '24 hours' GROUP BY service_id ORDER BY value DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "시간대별 이벤트",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT time_bucket('1 hour', time) AS time, event_type, COUNT(*) AS value FROM user_events WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "서비스별 이벤트",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT service_id, event_type, COUNT(*) as count FROM user_events WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 20",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 6,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "유입 경로 Top 20",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT metadata->>'referrer' as referrer, COUNT(*) as visits FROM user_events WHERE $__timeFilter(time) AND event_type = 'page_view' AND metadata->>'referrer' IS NOT NULL GROUP BY 1 ORDER BY 2 DESC LIMIT 20",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "title": "이벤트 타입별 분포 (7일)",
      "type": "piechart",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT event_type, COUNT(*) as count FROM user_events WHERE time > NOW() - INTERVAL '7 days' GROUP BY event_type ORDER BY count DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "서비스별 이벤트 분포 (7일)",
      "type": "piechart",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT service_id, COUNT(*) as count FROM user_events WHERE time > NOW() - INTERVAL '7 days' GROUP BY service_id ORDER BY count DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 20,
      "title": "PM2 프로세스 (Windows)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 16, "x": 0, "y": 30 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "프로세스 상태",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "pm2_up",
        "legendFormat": "{{name}}",
        "refId": "A",
        "instant": true
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 30 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "재시작 횟수",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "pm2_restarts",
        "legendFormat": "{{name}}",
        "refId": "A",
        "instant": true
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 34 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "PM2 CPU 추이",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "pm2_cpu",
        "legendFormat": "{{name}}",
        "refId": "A"
      }]
    },
