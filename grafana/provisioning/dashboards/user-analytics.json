      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decmbytes" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 34 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "PM2 메모리 추이",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "pm2_memory / 1024 / 1024",
        "legendFormat": "{{name}}",
        "refId": "A"
      }]
