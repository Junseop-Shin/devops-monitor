      "targets": [{
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "rawSql": "SELECT event_type, COUNT(*) as count FROM user_events WHERE ts > NOW() - INTERVAL '7 days' GROUP BY event_type ORDER BY count DESC",
        "format": "table",
        "refId": "A"
      }]
    }
