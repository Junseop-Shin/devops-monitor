      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({host=~\"$host\", container=~\"$container\"} [1m])) by (container)",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 2,
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "multi" } },
      "title": "에러 로그 발생률",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate({host=~\"$host\", container=~\"$container\"} |~ \"(?i)(error|exception|fatal)\" [1m])) by (container)",
          "legendFormat": "{{container}} 에러"
        }
      ]
    },
