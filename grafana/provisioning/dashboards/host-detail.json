{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "호스트별 상세 메트릭",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(node_uname_info, job)",
        "hide": 0,
        "includeAll": false,
        "label": "호스트",
        "name": "host",
        "options": [],
        "query": { "query": "label_values(node_uname_info, job)", "refId": "StandardVariableQuery" },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU 사용률",
      "type": "stat",
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"$host\"}[5m])) * 100)", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "메모리 사용률",
      "type": "stat",
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"$host\"} / node_memory_MemTotal_bytes{job=\"$host\"})) * 100", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "전체 메모리",
      "type": "stat",
      "targets": [{ "expr": "node_memory_MemTotal_bytes{job=\"$host\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "가동 시간",
      "type": "stat",
      "targets": [{ "expr": "node_time_seconds{job=\"$host\"} - node_boot_time_seconds{job=\"$host\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "CPU 사용률 (모드별)",
      "type": "timeseries",
      "targets": [
        { "expr": "avg by(mode) (rate(node_cpu_seconds_total{job=\"$host\"}[5m])) * 100", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "메모리 상세",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"$host\"}", "legendFormat": "전체" },
        { "expr": "node_memory_MemAvailable_bytes{job=\"$host\"}", "legendFormat": "여유" },
        { "expr": "node_memory_Cached_bytes{job=\"$host\"}", "legendFormat": "캐시" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used%" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "디스크 사용률",
      "type": "table",
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"$host\",fstype!~\"tmpfs|fuse.lxcfs\"} / node_filesystem_size_bytes{job=\"$host\",fstype!~\"tmpfs|fuse.lxcfs\"}) * 100",
          "legendFormat": "{{mountpoint}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "사용률%", "mountpoint": "마운트" } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "네트워크 트래픽",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"$host\",device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "수신 {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{job=\"$host\",device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "송신 {{device}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "디스크 I/O",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{job=\"$host\"}[5m])", "legendFormat": "읽기 {{device}}" },
        { "expr": "rate(node_disk_written_bytes_total{job=\"$host\"}[5m])", "legendFormat": "쓰기 {{device}}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["host"],
  "title": "호스트 상세",
  "uid": "host-detail",
  "version": 1
}
