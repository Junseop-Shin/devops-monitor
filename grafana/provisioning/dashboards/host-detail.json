          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - node_filesystem_avail_bytes{job=\"$job\",fstype!~\"tmpfs|fuse.lxcfs\"} / node_filesystem_size_bytes{job=\"$job\",fstype!~\"tmpfs|fuse.lxcfs\"}) * 100",
          "legendFormat": "{{mountpoint}}",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "사용률%", "mountpoint": "마운트" } } }
      ]
    },
