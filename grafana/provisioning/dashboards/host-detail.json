        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(node_network_transmit_bytes_total{job=\"$job\",device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "송신 {{device}}", "refId": "B" }
